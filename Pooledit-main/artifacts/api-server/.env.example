# Required
DATABASE_URL=postgres://user:password@localhost:5432/aquarich

# Server
NODE_ENV=development
PORT=5000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATA_DIR=./data

# Security
# Required when NODE_ENV=production.
JWT_SECRET=replace-with-a-long-random-secret
DATA_ENCRYPTION_KEY=replace-with-32-byte-base64-or-64-char-hex-key

# Mail / OTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=Aquarich

# Backups
BACKUP_HOUR=2
BACKUP_KEEP=30

# AI assistant
AI_CHAT_ENABLED=false
OLLAMA_URL=http://127.0.0.1:11434
AI_MODEL=scb10x/typhoon2.5-qwen3-4b

# Slip verification / OCR
OCR_LANG=tha+eng
OCR_LANG_PATH=
TESSDATA_PREFIX=
MERCHANT_ACCOUNT_NAME=
MERCHANT_ACCOUNT_NUMBER=

# Optional integrations
FIREBASE_PROJECT_ID=
N2_TICKET_URL=
